    "@angular/router": "^21.2.17",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "ngx-sonner": "^3.1.0",
    "ngx-toastr": "^19.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.15",
